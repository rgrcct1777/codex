# Copy this file to .env and replace placeholders before running.

# n8n app URL settings
N8N_HOST=replace_me
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=replace_me
WEBHOOK_URL=replace_me

# Local machine timezone settings
TZ=America/Los_Angeles
GENERIC_TIMEZONE=America/Los_Angeles

# For local HTTP setup, keep false.
# Set true only when you add HTTPS via reverse proxy.
N8N_SECURE_COOKIE=false

# Placeholders for values you will paste inside n8n UI
NOTION_API_KEY=replace_me
NOTION_DATABASE_ID=replace_me
