# Copy this file to .env and fill in any values still marked replace_me.

# Core n8n URL settings for local development
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/

# Timezone settings
TZ=America/Los_Angeles
GENERIC_TIMEZONE=America/Los_Angeles

# Keep false for plain HTTP localhost.
# Set true only when using HTTPS behind a reverse proxy.
N8N_SECURE_COOKIE=false

# Strongly recommended: set a long random value so encrypted credentials
# stay readable across container recreates and machine restarts.
# Example: openssl rand -base64 32
N8N_ENCRYPTION_KEY=replace_me

# Optional privacy/safety defaults
N8N_DIAGNOSTICS_ENABLED=false
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# Placeholders you will paste inside n8n (Credentials / node config)
NOTION_API_KEY=replace_me
NOTION_DATABASE_ID=replace_me
